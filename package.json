{
  "name": "atomquest-goal-portal",
  "version": "1.0.0",
  "description": "In-House Goal Setting & Tracking Portal for AtomQuest Hackathon 1.0",
  "private": true,
  "workspaces": [
    "server",
    "client"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=server\" \"npm run dev --workspace=client\"",
    "build": "npm run build --workspace=client && npm run check --workspace=server",
    "start": "npm run start --workspace=server",
    "vercel-build": "npm run build --workspace=client",
    "check": "npm run check --workspace=server",
    "install:all": "npm install"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
