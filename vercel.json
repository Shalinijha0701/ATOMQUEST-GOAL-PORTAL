{
  "version": 2,
  "installCommand": "npm install",
  "buildCommand": "npm run build --workspace=client",
  "outputDirectory": "client/dist",
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/[...slug].js"
    },
    {
      "src": "^/(.*)$",
      "dest": "/index.html"
    }
  ]
}
